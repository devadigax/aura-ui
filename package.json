{
  "name": "@devadigax/aura-ui",
  "version": "4.0.0",
  "sideEffects": [
    "**/*.css",
    "./dist/style.css"
  ],
  "description": "A modern glassmorphism component library built with React",
  "type": "module",
  "main": "./dist/aura-ui.umd.cjs",
  "module": "./dist/aura-ui.js",
  "exports": {
    ".": {
      "import": "./dist/aura-ui.js",
      "require": "./dist/aura-ui.umd.cjs",
      "style": "./dist/style.css"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "cross-env BUILD_MODE=lib vite build",
    "build:showcase": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "vite": "^5.4.11"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "ui",
    "glassmorphism",
    "components",
    "glass-ui",
    "aura-ui",
    "dark-mode"
  ],
  "author": "devadigax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devadigax/aura-ui.git"
  },
  "bugs": {
    "url": "https://github.com/devadigax/aura-ui/issues"
  },
  "homepage": "https://github.com/devadigax/aura-ui#readme"
}